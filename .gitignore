build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript v1.x command line compiler temporary cache
active.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional microbundle cache
.microbundle

# Default binary mirror vars
.nvmrc

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
